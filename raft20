    local bt = Instance.new("TextButton", f); bt.Text = ""; bt.Size = UDim2.new(0, 35, 0, 18); bt.Position = UDim2.new(1, -45, 0.5, -9); bt.BackgroundColor3 = Color3.fromRGB(80, 80, 80); Instance.new("UICorner", bt).CornerRadius = UDim.new(1, 0)
    bt.MouseButton1Click:Connect(function() _G[var] = not _G[var]; bt.BackgroundColor3 = _G[var] and Themes.On or Color3.fromRGB(80, 80, 80) end)
end

local function createSpeedControl(parent)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.98, 0, 0, 45); f.BackgroundColor3 = Themes.Accent; Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
    local l = Instance.new("TextLabel", f); l.Text = "  Velocidad: " .. _G.SPD_VAL; l.Size = UDim2.new(0.5, 0, 1, 0); l.BackgroundTransparency = 1; l.TextColor3 = Themes.Text; l.Font = "GothamBold"; l.TextSize = 12; l.TextXAlignment = "Left"
    local function addB(t, x, amt)
        local b = Instance.new("TextButton", f); b.Text = t; b.Size = UDim2.new(0, 35, 0, 30); b.Position = UDim2.new(1, x, 0.5, -15); b.BackgroundColor3 = Themes.TopBar; b.TextColor3 = Themes.Text; b.Font = "GothamBold"; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 5)
        b.MouseButton1Click:Connect(function() _G.SPD_VAL = math.clamp(_G.SPD_VAL + amt, 16, 250); l.Text = "  Velocidad: " .. _G.SPD_VAL end)
    end
    addB("+5", -40, 5); addB("-5", -80, -5)
end

