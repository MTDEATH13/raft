-- LÓGICA AUTO TALAR FIX (LA RÁPIDA SECUENCIAL)
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoTalar then
            pcall(function()
                local remote = ReplicatedStorage:FindFirstChild("AxeHit")
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                if remote and tool then
                    for _, isl in pairs(workspace._Debris.Islands:GetChildren()) do
                        local trees = isl:FindFirstChild("Objects") and isl.Objects:FindFirstChild("Trees")
                        if trees then
                            local target = trees:FindFirstChildWhichIsA("Model")
                            if target then
                                for i = 43, 0, -5 do -- Ráfaga rápida pero controlada
                                    if not _G.AutoTalar or not target.Parent then break end
                                    remote:FireServer(target, "tree", i)
                                    tool:Activate()
                                    task.wait(0.05)
                                end
                                break 
                            end
                        end
                    end
                end
            end)
        end
        if _G.AutoFire then
            pcall(function()
                local b = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do if log.Name == "Log" then (log:FindFirstChild("Part") or log).CFrame = b.CFrame end end
            end)
        end
    end
end)

-- LÓGICA KILL AURA (FIX GIRO)
task.spawn(function()
    while task.wait(0.2) do
        if _G.AuraActive then
            pcall(function()
                local root = LP.Character.HumanoidRootPart
                local remote = ReplicatedStorage.AxeHit
                for _, npc in pairs(workspace._Debris.NPCs:GetChildren()) do
                    local tPart = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Part")
                    if tPart and (root.Position - tPart.Position).Magnitude <= 60 then
                        HitCounter = (HitCounter % 50) + 1
                        local mode = (npc:FindFirstChild("Humanoid")) and "npc_humanoid" or "npc_attribute"
                        remote:FireServer(npc, mode, HitCounter)
                    end
                end
            end)
        end
    end
end)

-- MOVIMIENTO (Noclip y Speed)
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character then
            if _G.NOCLIP_ON then for _, p in pairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
            if _G.SPEED_ON and LP.Character:FindFirstChild("HumanoidRootPart") then
                local h = LP.Character.Humanoid
                if h and h.MoveDirection.Magnitude > 0 then LP.Character.HumanoidRootPart.CFrame += h.MoveDirection * ((_G.SPD_VAL - 16) / 45) end
            end
        end
    end)
end)
