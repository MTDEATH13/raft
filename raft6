-- 6. ELEMENTOS DE INTERFAZ (Toggles y Botones estilo Moderno)
local function createToggle(txt, parent, varName, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(0.98, 0, 0, 40); f.BackgroundColor3 = Themes.Accent; f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
    
    local lbl = Instance.new("TextLabel", f)
    lbl.Text = "  "..txt; lbl.Size = UDim2.new(0.7, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Themes.Text; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local btnT = Instance.new("TextButton", f)
    btnT.Text = ""; btnT.Size = UDim2.new(0, 45, 0, 22); btnT.Position = UDim2.new(1, -55, 0.5, -11)
    btnT.BackgroundColor3 = Color3.fromRGB(80, 80, 80); btnT.BorderSizePixel = 0
    Instance.new("UICorner", btnT).CornerRadius = UDim.new(1, 0) -- Switch redondo
    
    local circle = Instance.new("Frame", btnT)
    circle.Size = UDim2.new(0, 18, 0, 18); circle.Position = UDim2.new(0, 2, 0.5, -9)
    circle.BackgroundColor3 = Color3.new(1,1,1); circle.BorderSizePixel = 0
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
    
    -- Actualizar estado inicial
    if _G[varName] then
        btnT.BackgroundColor3 = Themes.ToggleOn
        circle.Position = UDim2.new(1, -20, 0.5, -9)
    end

    btnT.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        local on = _G[varName]
        TS:Create(btnT, TweenInfo.new(0.2), {BackgroundColor3 = on and Themes.ToggleOn or Color3.fromRGB(80, 80, 80)}):Play()
        TS:Create(circle, TweenInfo.new(0.2), {Position = on and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)}):Play()
        if callback then callback(on) end
    end)
    return f
end

