-- [[ POTO1 HUB v59 - CORRECCIÓN DE TALAR SINCRONIZADO ]]
local LP = game:GetService("Players").LocalPlayer
local RS = game:GetService("RunService")

_G.PotoConfig = {Talar = false, Fire = false, Noclip = false, Speed = false, SpdVal = 16}

local pgui = LP:WaitForChild("PlayerGui")
if pgui:FindFirstChild("PotoHub") then pgui.PotoHub:Destroy() end

local sg = Instance.new("ScreenGui", pgui); sg.Name = "PotoHub"
local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 180, 0, 310); main.Position = UDim2.new(0.1, 0, 0.4, 0)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); main.Active = true; main.Draggable = true

local function btn(txt, y, cb)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = UDim2.new(0.05, 0, 0, y)
    b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1, 1, 1)
    b.MouseButton1Click:Connect(function() cb(b) end)
    return b
end

btn("AUTO TALAR: OFF", 15, function(b) _G.PotoConfig.Talar = not _G.PotoConfig.Talar; b.Text = "TALAR: "..(_G.PotoConfig.Talar and "ON" or "OFF") end)
btn("NOCLIP: OFF", 55, function(b) _G.PotoConfig.Noclip = not _G.PotoConfig.Noclip; b.Text = "NOCLIP: "..(_G.PotoConfig.Noclip and "ON" or "OFF") end)
btn("AUTO FIRE: OFF", 95, function(b) _G.PotoConfig.Fire = not _G.PotoConfig.Fire; b.Text = "FIRE: "..(_G.PotoConfig.Fire and "ON" or "OFF") end)
btn("SPEED: OFF", 135, function(b) _G.PotoConfig.Speed = not _G.PotoConfig.Speed; b.Text = "SPEED: "..(_G.PotoConfig.Speed and "ON" or "OFF") end)

-- LÓGICA DE MOVIMIENTO
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character and _G.PotoConfig.Noclip then
            for _, p in pairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
        end
        if LP.Character and _G.PotoConfig.Speed and LP.Character:FindFirstChild("HumanoidRootPart") then
            local hum = LP.Character:FindFirstChild("Humanoid")
            if hum and hum.MoveDirection.Magnitude > 0 then
                LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame + (hum.MoveDirection * ((_G.PotoConfig.SpdVal - 16) / 35))
            end
        end
    end)
end)

-- LÓGICA DE FARMEO CORREGIDA
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if _G.PotoConfig.Talar then
                local rem = game:GetService("ReplicatedStorage"):FindFirstChild("AxeHit")
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                if tool and rem then
                    for _, isl in pairs(workspace._Debris.Islands:GetChildren()) do
                        local trees = isl:FindFirstChild("Objects") and isl.Objects:FindFirstChild("Trees")
                        local tree = trees and trees:FindFirstChildWhichIsA("Model")
                        if tree and tree:FindFirstChild("Health") then
                            -- AQUÍ ESTÁ EL TRUCO: Bajamos la vida de 1 en 1 respetando al servidor
                            local h_val = tree.Health.Value
                            if h_val > 0 then
                                rem:FireServer(tree, "tree", h_val - 1)
                                tool:Activate()
                            end
                            break
                        end
                    end
                end
            end
            if _G.PotoConfig.Fire then
                local base = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do
                    if log.Name == "Log" then (log:FindFirstChild("Part") or log).CFrame = base.CFrame end
                end
            end
        end)
    end
end)
