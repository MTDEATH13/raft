main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); main.BorderSizePixel = 2
main.Active = true; main.Draggable = true

local function crearBoton(txt, y, cb)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = UDim2.new(0.05, 0, 0, y)
    b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 12
    b.MouseButton1Click:Connect(function() cb(b) end)
    return b
end

-- BOTONES
crearBoton("AUTO TALAR: OFF", 15, function(b) 
    _G.PotoConfig.Talar = not _G.PotoConfig.Talar
    b.Text = "TALAR: " .. (_G.PotoConfig.Talar and "ON" or "OFF")
end)

