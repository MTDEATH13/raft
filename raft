-- [[ POTO1 HUB v58 - VERSIÓN FINAL CORREGIDA ]]
local LP = game:GetService("Players").LocalPlayer
local RS = game:GetService("RunService")

-- 1. CONFIGURACIÓN GLOBAL (VALORES INICIALES)
_G.PotoConfig = {
    Talar = false,
    Fire = false,
    Noclip = false,
    Speed = false,
    SpdVal = 16
}

-- 2. INTERFAZ (MENÚ POTO1)
local pgui = LP:WaitForChild("PlayerGui")
if pgui:FindFirstChild("PotoHub") then pgui.PotoHub:Destroy() end

local sg = Instance.new("ScreenGui", pgui); sg.Name = "PotoHub"
local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 180, 0, 310); main.Position = UDim2.new(0.1, 0, 0.4, 0)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); main.Active = true; main.Draggable = true

local function crearBoton(txt, y, cb)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.9, 0, 0, 35); b.Position = UDim2.new(0.05, 0, 0, y)
    b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 12
    b.MouseButton1Click:Connect(function() cb(b) end)
    return b
end

-- BOTONES DE ACCIÓN
crearBoton("AUTO TALAR: OFF", 15, function(b) 
    _G.PotoConfig.Talar = not _G.PotoConfig.Talar
    b.Text = "TALAR: " .. (_G.PotoConfig.Talar and "ON" or "OFF")
end)

crearBoton("NOCLIP: OFF", 55, function(b) 
    _G.PotoConfig.Noclip = not _G.PotoConfig.Noclip
    b.Text = "NOCLIP: " .. (_G.PotoConfig.Noclip and "ON" or "OFF")
end)

crearBoton("AUTO FIRE: OFF", 95, function(b) 
    _G.PotoConfig.Fire = not _G.PotoConfig.Fire
    b.Text = "FIRE: " .. (_G.PotoConfig.Fire and "ON" or "OFF")
end)

crearBoton("SPEED: OFF", 135, function(b) 
    _G.PotoConfig.Speed = not _G.PotoConfig.Speed
    b.Text = "SPEED: " .. (_G.PotoConfig.Speed and "ON" or "OFF")
end)

local label = Instance.new("TextLabel", main)
label.Size = UDim2.new(0.9, 0, 0, 20); label.Position = UDim2.new(0.05, 0, 0, 175)
label.Text = "VELOCIDAD: 16"; label.BackgroundTransparency = 1; label.TextColor3 = Color3.new(1, 1, 1)

crearBoton("-5", 200, function() 
    _G.PotoConfig.SpdVal = math.max(16, _G.PotoConfig.SpdVal - 5)
    label.Text = "VELOCIDAD: " .. _G.PotoConfig.SpdVal
end).Size = UDim2.new(0.42, 0, 0, 35)

local p5 = crearBoton("+5", 200, function() 
    _G.PotoConfig.SpdVal = _G.PotoConfig.SpdVal + 5
    label.Text = "VELOCIDAD: " .. _G.PotoConfig.SpdVal
end)
p5.Size = UDim2.new(0.42, 0, 0, 35); p5.Position = UDim2.new(0.53, 0, 0, 200)

crearBoton("CERRAR SCRIPT", 260, function() sg:Destroy() end).BackgroundColor3 = Color3.fromRGB(80, 20, 20)

-- 3. LÓGICA DE MOVIMIENTO (NOCLIP Y SPEED)
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character then
            -- Noclip
            if _G.PotoConfig.Noclip then
                for _, p in pairs(LP.Character:GetDescendants()) do
                    if p:IsA("BasePart") and p.CanCollide then p.CanCollide = false end
                end
            end
            -- Speed (CFrame para que no te regrese el anticheat)
            if _G.PotoConfig.Speed and LP.Character:FindFirstChild("HumanoidRootPart") then
                local hum = LP.Character:FindFirstChild("Humanoid")
                if hum and hum.MoveDirection.Magnitude > 0 then
                    LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame + (hum.MoveDirection * ((_G.PotoConfig.SpdVal - 16) / 40))
                end
            end
        end
    end)
end)

-- 4. LÓGICA DE FARMEO (TALAR Y FIRE)
task.spawn(function()
    while task.wait(0.3) do
        pcall(function()
            -- Auto Talar Respetando Vida del Árbol
            if _G.PotoConfig.Talar then
                local rem = game:GetService("ReplicatedStorage"):FindFirstChild("AxeHit")
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                
                if tool and rem then
                    for _, isl in pairs(workspace._Debris.Islands:GetChildren()) do
                        local trees = isl:FindFirstChild("Objects") and isl.Objects:FindFirstChild("Trees")
                        local tree = trees and trees:FindFirstChildWhichIsA("Model")
                        
                        if tree and tree:FindFirstChild("Health") then
                            local h = tree.Health.Value
                            -- Bucle que baja la vida de 2 en 2 para que el server lo acepte
                            for i = h, 0, -2 do
                                if not _G.PotoConfig.Talar or not tree.Parent then break end
                                rem:FireServer(tree, "tree", i)
                                tool:Activate()
                                task.wait(0.04) -- Tiempo justo para que no se trabe
                            end
                            break
                        end
                    end
                end
            end
            
            -- Auto Fire (Mover troncos a la fogata)
            if _G.PotoConfig.Fire then
                local base = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do
                    if log.Name == "Log" then 
                        local part = log:FindFirstChild("Part") or log
                        part.CFrame = base.CFrame 
                    end
                end
            end
        end)
    end
end)

print("POTO1 Hub v58: ¡Todo listo!")
