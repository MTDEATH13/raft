    img.Name = "Icon"; img.Size = UDim2.new(0, 24, 0, 24); img.Position = UDim2.new(0.5, -12, 0.5, -12); img.BackgroundTransparency = 1
    img.Image = "rbxassetid://"..iconId; img.ImageColor3 = Color3.new(0.8,0.8,0.8); img.ZIndex = 6

    b.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
