-- 6. ELEMENTOS DE INTERFAZ (Toggles y Botones)
local function createToggle(txt, parent, varName, callback)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.98, 0, 0, 40); f.BackgroundColor3 = Themes.Accent; f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
    local lbl = Instance.new("TextLabel", f); lbl.Text = "  "..txt; lbl.Size = UDim2.new(0.7, 0, 1, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Themes.Text; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local btnT = Instance.new("TextButton", f); btnT.Text = ""; btnT.Size = UDim2.new(0, 40, 0, 20); btnT.Position = UDim2.new(1, -50, 0.5, -10); btnT.BackgroundColor3 = Color3.fromRGB(80, 80, 80); btnT.BorderSizePixel = 0
    Instance.new("UICorner", btnT).CornerRadius = UDim.new(1, 0)
    local circle = Instance.new("Frame", btnT); circle.Size = UDim2.new(0, 16, 0, 16); circle.Position = UDim2.new(0, 2, 0.5, -8); circle.BackgroundColor3 = Color3.new(1,1,1); circle.BorderSizePixel = 0; Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
    
    if _G[varName] then btnT.BackgroundColor3 = Themes.ToggleOn; circle.Position = UDim2.new(1, -18, 0.5, -8) end
    btnT.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]; local on = _G[varName]
        TS:Create(btnT, TweenInfo.new(0.2), {BackgroundColor3 = on and Themes.ToggleOn or Color3.fromRGB(80, 80, 80)}):Play()
        TS:Create(circle, TweenInfo.new(0.2), {Position = on and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}):Play()
        if callback then callback(on) end
    end); return f
end

