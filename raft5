-- FUNCIÓN PARA BOTONES DE OPCIÓN
local function addToggle(txt, parent, y, cb)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(0.95, 0, 0, 35); b.Position = UDim2.new(0, 0, 0, y)
    b.BackgroundColor3 = Color3.fromRGB(45, 45, 45); b.Text = txt; b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.Gotham; b.TextSize = 12
    -- CORRECCIÓN AQUÍ: Usamos UDim.new en lugar de BoxUnit o ToolUnit
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    b.MouseButton1Click:Connect(function() cb(b) end)
    return b
end

