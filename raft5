-- LÓGICA DE MOVIMIENTO
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character then
            if _G.NOCLIP_ON then
                for _, p in pairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
            end
            if _G.SPEED_ON and LP.Character:FindFirstChild("HumanoidRootPart") then
                local hum = LP.Character:FindFirstChild("Humanoid")
                if hum and hum.MoveDirection.Magnitude > 0 then
                    LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame + (hum.MoveDirection * ((_G.SPD_VAL - 16) / 30))
                end
            end
        end
    end)
end)

-- LÓGICA HYPER-DRIVE (TALAR Y FIRE)
task.spawn(function()
    while task.wait(0.05) do 
        if _G.AutoTalar then
            pcall(function()
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("AxeHit")
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                if remote and tool then
                    local target = nil
                    for _, isl in pairs(workspace._Debris.Islands:GetChildren()) do
                        local trees = isl:FindFirstChild("Objects") and isl.Objects:FindFirstChild("Trees")
                        if trees then target = trees:FindFirstChildWhichIsA("Model"); if target then break end end
                    end
                    if target then
                        -- Secuencia de ráfaga rápida (Hyper-Burst)
                        for i = 43, 1, -5 do 
                            if not target.Parent or not _G.AutoTalar then break end
                            remote:FireServer(target, "tree", i); remote:FireServer(target, "tree", i-1); remote:FireServer(target, "tree", i-2)
                            if i == 43 then tool:Activate() end
                            task.wait() 
                        end
                    end
                end
            end)
        end
        if _G.AutoFire then
            pcall(function()
                local base = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do
                    if log.Name == "Log" then (log:FindFirstChild("Part") or log).CFrame = base.CFrame end
                end
            end)
        end
    end
end)
