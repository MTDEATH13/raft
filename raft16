-- LÓGICA HYPER-DRIVE CORREGIDA (Velocidad Crítica Real)
task.spawn(function()
    while task.wait(0.05) do
        if _G.AutoTalar then
            pcall(function()
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("AxeHit")
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                
                if remote and tool then
                    for _, island in pairs(workspace._Debris.Islands:GetChildren()) do
                        local trees = island:FindFirstChild("Objects") and island.Objects:FindFirstChild("Trees")
                        if trees then
                            local targetTree = trees:FindFirstChildWhichIsA("Model")
                            if targetTree then
                                -- Secuencia Hyper: Baja la vida de 1 en 1 pero sin pausas largas
                                for i = 43, 0, -1 do
                                    if not _G.AutoTalar or not targetTree.Parent then break end
                                    remote:FireServer(targetTree, "tree", i)
                                    if i % 5 == 0 then tool:Activate() end -- Animación cada 5 golpes para evitar lag
                                    task.wait() -- Micro-pausa obligatoria para que el servidor no te ignore
                                end
                                break 
                            end
                        end
                    end
                end
            end)
        end
        
        -- Auto-Fire
        if _G.AutoFire then
            pcall(function()
                local base = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do
                    if log.Name == "Log" then (log:FindFirstChild("Part") or log).CFrame = base.CFrame end
                end
            end)
        end
    end
end)
