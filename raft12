-- LÓGICA KILL AURA (Basada en tus capturas de SimpleSpy)
task.spawn(function()
    local remote = game:GetService("ReplicatedStorage"):WaitForChild("AxeHit")
    local debrisNPCs = workspace:WaitForChild("_Debris"):WaitForChild("NPCs")
    
    while task.wait(0.1) do
        if _G.KillAura then
            pcall(function()
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    for _, npc in pairs(debrisNPCs:GetChildren()) do
                        local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Base")
                        local hum = npc:FindFirstChild("Humanoid")
                        
                        if hum and hum.Health > 0 and root then
                            local dist = (LP.Character.HumanoidRootPart.Position - root.Position).Magnitude
                            if dist < 30 then
                                -- Formato exacto de tus capturas
                                remote:FireServer(npc, "npc_attribute", math.random(95, 100))
                                tool:Activate()
                            end
                        end
                    end
                end
            end)
        end
    end
end)

