-- FUNCIÓN TOGGLE
local function createToggle(txt, parent, var)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.95, 0, 0, 35); f.BackgroundColor3 = Themes.Accent; Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
    local l = Instance.new("TextLabel", f); l.Text = "  "..txt; l.Size = UDim2.new(0.7, 0, 1, 0); l.BackgroundTransparency = 1; l.TextColor3 = Themes.Text; l.Font = "Gotham"; l.TextSize = 12; l.TextXAlignment = "Left"
    local bt = Instance.new("TextButton", f); bt.Text = ""; bt.Size = UDim2.new(0, 35, 0, 18); bt.Position = UDim2.new(1, -40, 0.5, -9); bt.BackgroundColor3 = Color3.fromRGB(100, 100, 100); Instance.new("UICorner", bt).CornerRadius = UDim.new(1, 0)
    bt.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        bt.BackgroundColor3 = _G[var] and Themes.On or Color3.fromRGB(100, 100, 100)
    end)
end

