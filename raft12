-- MOVIMIENTO (NOCLIP Y SPEED)
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character then
            if _G.NOCLIP_ON then 
                for _, p in pairs(LP.Character:GetDescendants()) do 
                    if p:IsA("BasePart") then p.CanCollide = false end 
                end 
            end
            if _G.SPEED_ON and LP.Character:FindFirstChild("HumanoidRootPart") then
                local h = LP.Character:FindFirstChild("Humanoid")
                if h and h.MoveDirection.Magnitude > 0 then
                    LP.Character.HumanoidRootPart.CFrame += h.MoveDirection * (_G.SPD_VAL / 40)
                end
            end
        end
    end)
end)

