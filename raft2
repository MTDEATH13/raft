local LP = game:GetService("Players").LocalPlayer
local RS = game:GetService("RunService")

-- VARIABLES GLOBALES
_G.AutoFire = false
_G.AutoTalar = false
_G.SPEED_ON = false
_G.NOCLIP_ON = false
_G.SPD_VAL = 16 

-- INTERFAZ (DISEÑO V58 UNIFICADO)
local pgui = LP:WaitForChild("PlayerGui")
if pgui:FindFirstChild("FinalDelta_V58") then pgui.FinalDelta_V58:Destroy() end

local sg = Instance.new("ScreenGui", pgui); sg.Name = "FinalDelta_V58"
local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 180, 0, 350); main.Position = UDim2.new(0.1, 0, 0.4, 0)
main.BackgroundColor3 = Color3.new(0, 0, 0); main.Active = true; main.Draggable = true

local function btn(txt, y, x, sizeX, cb)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(sizeX, 0, 0, 35); b.Position = UDim2.new(x, 0, 0, y)
    b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(40, 40, 40); b.TextColor3 = Color3.new(1, 1, 1)
    b.MouseButton1Click:Connect(function() cb(b) end)
    return b
end

-- BOTONES
btn("AUTO TALAR: OFF", 15, 0.05, 0.9, function(b) 
    _G.AutoTalar = not _G.AutoTalar
    b.Text = "TALAR: " .. (_G.AutoTalar and "ON" or "OFF")
end)

btn("AUTO FIRE: OFF", 55, 0.05, 0.9, function(b) 
    _G.AutoFire = not _G.AutoFire
    b.Text = "FIRE: " .. (_G.AutoFire and "ON" or "OFF")
end)

btn("NOCLIP: OFF", 95, 0.05, 0.9, function(b) 
    _G.NOCLIP_ON = not _G.NOCLIP_ON
    b.Text = "NOCLIP: " .. (_G.NOCLIP_ON and "ON" or "OFF")
end)

btn("SPEED: OFF", 135, 0.05, 0.9, function(b) 
    _G.SPEED_ON = not _G.SPEED_ON
    b.Text = "SPEED: " .. (_G.SPEED_ON and "ON" or "OFF")
end)

local spdLabel = btn("VALOR: " .. _G.SPD_VAL, 175, 0.05, 0.9, function() end)

btn("-5", 215, 0.05, 0.42, function() 
    _G.SPD_VAL = math.max(16, _G.SPD_VAL - 5)
    spdLabel.Text = "VALOR: " .. _G.SPD_VAL
end)

btn("+5", 215, 0.53, 0.42, function() 
    _G.SPD_VAL = _G.SPD_VAL + 5
    spdLabel.Text = "VALOR: " .. _G.SPD_VAL
end)

btn("TP BASE", 260, 0.05, 0.9, function() 
    pcall(function() LP.Character.HumanoidRootPart.CFrame = workspace._Raft.Campfire.Base.CFrame + Vector3.new(0, 5, 0) end) 
end)

btn("CERRAR", 305, 0.05, 0.9, function() sg:Destroy() end)

-- LÓGICA DE MOVIMIENTO (SPEED + NOCLIP)
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character then
            if _G.NOCLIP_ON then
                for _, part in pairs(LP.Character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
            if _G.SPEED_ON and LP.Character:FindFirstChild("HumanoidRootPart") then
                local hum = LP.Character:FindFirstChild("Humanoid")
                if hum and hum.MoveDirection.Magnitude > 0 then
                    LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame + (hum.MoveDirection * ((_G.SPD_VAL - 16) / 30))
                end
            end
        end
    end)
end)

-- MOTOR HYPER-DRIVE (TALAR Y FIRE)
task.spawn(function()
    while task.wait(0.05) do 
        -- AUTO-TALAR HYPER-BURST
        if _G.AutoTalar then
            pcall(function()
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("AxeHit")
                local tool = LP.Character:FindFirstChildWhichIsA("Tool")
                
                if remote and tool then
                    local targetTree = nil
                    for _, island in pairs(workspace._Debris.Islands:GetChildren()) do
                        local trees = island:FindFirstChild("Objects") and island.Objects:FindFirstChild("Trees")
                        if trees then
                            targetTree = trees:FindFirstChildWhichIsA("Model")
                            if targetTree then break end
                        end
                    end

                    if targetTree then
                        -- Secuencia de ráfaga rápida
                        for i = 43, 1, -5 do 
                            if not targetTree.Parent or not _G.AutoTalar then break end
                            remote:FireServer(targetTree, "tree", i)
                            remote:FireServer(targetTree, "tree", i-1)
                            remote:FireServer(targetTree, "tree", i-2)
                            if i == 43 then tool:Activate() end
                            task.wait() 
                        end
                    end
                end
            end)
        end

        -- AUTO-FIRE
        if _G.AutoFire then
            pcall(function()
                local base = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do
                    if log.Name == "Log" then (log:FindFirstChild("Part") or log).CFrame = base.CFrame end
                end
            end)
        end
    end
end)
