end)

btn("CERRAR", 265, 0.05, 0.9, function() sg:Destroy() _G.SPEED_ON=false _G.AutoTalar=false _G.NOCLIP_ON=false end)

-- LÓGICA DE MOVIMIENTO (SPEED + NOCLIP UNIFICADOS)
RS.Stepped:Connect(function()
    pcall(function()
        if LP.Character then
            -- Lógica de Noclip
            if _G.NOCLIP_ON then
                for _, part in pairs(LP.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            end
            -- Tu lógica de Speed original
            if _G.SPEED_ON and LP.Character:FindFirstChild("HumanoidRootPart") then
                local hum = LP.Character:FindFirstChild("Humanoid")
                if hum and hum.MoveDirection.Magnitude > 0 then
                    LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame + (hum.MoveDirection * ((_G.SPD_VAL - 16) / 30))
                end
            end
        end
    end)
end)

-- MOTOR DE JUEGO ORIGINAL (TALAR Y FIRE)
task.spawn(function()
    while task.wait(0.2) do
        pcall(function()
            local tool = LP.Character:FindFirstChildWhichIsA("Tool")
            local remote = game:GetService("ReplicatedStorage"):FindFirstChild("AxeHit")

            if _G.AutoTalar and tool and remote then
                for _, island in pairs(workspace._Debris.Islands:GetChildren()) do
                    local trees = island:FindFirstChild("Objects") and island.Objects:FindFirstChild("Trees")
                    local tree = trees and trees:FindFirstChildWhichIsA("Model")
                    if tree then
                        for i = 43, 1, -2 do
                            if not _G.AutoTalar or not tree.Parent then break end
                            remote:FireServer(tree, "tree", i)
                            tool:Activate()
                        end
                        break
                    end
                end
            end

            if _G.AutoFire then
                local base = workspace._Raft.Campfire.Base
                for _, log in pairs(workspace._Carryables:GetChildren()) do
                    if log.Name == "Log" then
                        (log:FindFirstChild("Part") or log).CFrame = base.CFrame
                    end
                end
            end
        end)
    end
end)
