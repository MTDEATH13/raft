local function createToggle(txt, parent, var)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.98, 0, 0, 38); f.BackgroundColor3 = Themes.Accent; Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
