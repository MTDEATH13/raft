    local function addB(t, x, amt)
        local b = Instance.new("TextButton", f); b.Text = t; b.Size = UDim2.new(0, 35, 0, 30); b.Position = UDim2.new(1, x, 0.5, -15); b.BackgroundColor3 = Themes.TopBar; b.TextColor3 = Themes.Text; b.Font = "GothamBold"; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 5)
