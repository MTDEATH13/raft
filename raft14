    local bt = Instance.new("TextButton", f); bt.Text = ""; bt.Size = UDim2.new(0, 35, 0, 18); bt.Position = UDim2.new(1, -45, 0.5, -9); bt.BackgroundColor3 = Color3.fromRGB(80, 80, 80); Instance.new("UICorner", bt).CornerRadius = UDim.new(1, 0)
    bt.MouseButton1Click:Connect(function() _G[var] = not _G[var]; bt.BackgroundColor3 = _G[var] and Themes.On or Color3.fromRGB(80, 80, 80) end)
end

local function createSpeedControl(parent)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.98, 0, 0, 45); f.BackgroundColor3 = Themes.Accent; Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
